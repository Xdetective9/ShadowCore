<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'System Logs' %> | ShadowCore Admin</title>
    <link rel="stylesheet" href="/static/css/main.css">
    <link rel="stylesheet" href="/static/css/admin.css">
</head>
<body>
    <div class="admin-layout">
        <%- include('../partials/admin-sidebar', { currentPage: 'logs' }) %>
        
        <main class="admin-content">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <h1>📝 System Logs</h1>
                <div style="display: flex; gap: 0.5rem;">
                    <button onclick="refreshLogs()" class="btn btn-secondary">🔄 Refresh</button>
                    <button onclick="clearLogs()" class="btn btn-danger">🗑️ Clear All</button>
                    <button onclick="exportLogs()" class="btn btn-primary">📥 Export</button>
                </div>
            </div>
            
            <!-- Log Filters -->
            <div class="card" style="margin-bottom: 1.5rem;">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
                    <div class="form-group">
                        <label>Log Level</label>
                        <select id="logLevel" class="form-control" onchange="filterLogs()">
                            <option value="all">All Levels</option>
                            <option value="info">Info</option>
                            <option value="warning">Warning</option>
                            <option value="error">Error</option>
                            <option value="success">Success</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label>Plugin</label>
                        <select id="logPlugin" class="form-control" onchange="filterLogs()">
                            <option value="all">All Plugins</option>
                            <% if (plugins && plugins.length > 0) { %>
                                <% plugins.forEach(plugin => { %>
                                    <option value="<%= plugin.id %>"><%= plugin.name %></option>
                                <% }) %>
                            <% } %>
                            <option value="system">System</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label>Time Range</label>
                        <select id="logTime" class="form-control" onchange="filterLogs()">
                            <option value="1h">Last Hour</option>
                            <option value="24h">Last 24 Hours</option>
                            <option value="7d">Last 7 Days</option>
                            <option value="30d">Last 30 Days</option>
                            <option value="all">All Time</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label>Search</label>
                        <input type="text" id="logSearch" class="form-control" placeholder="Search logs..." oninput="filterLogs()">
                    </div>
                </div>
            </div>
            
            <!-- Logs Table -->
            <div class="card">
                <div style="overflow-x: auto;">
                    <table class="logs-table" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 1px solid var(--border);">
                                <th style="text-align: left; padding: 1rem;">Time</th>
                                <th style="text-align: left; padding: 1rem;">Level</th>
                                <th style="text-align: left; padding: 1rem;">Plugin</th>
                                <th style="text-align: left; padding: 1rem;">User</th>
                                <th style="text-align: left; padding: 1rem;">Message</th>
                                <th style="text-align: left; padding: 1rem;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="logsTableBody">
                            <% if (logs && logs.length > 0) { %>
                                <% logs.forEach(log => { %>
                                    <tr class="log-row" 
                                        data-level="<%= log.level || 'info' %>"
                                        data-plugin="<%= log.plugin || 'system' %>"
                                        data-time="<%= new Date(log.timestamp).getTime() %>">
                                        <td style="padding: 1rem; color: var(--text-secondary); font-size: 0.9rem;">
                                            <%= new Date(log.timestamp).toLocaleString() %>
                                        </td>
                                        <td style="padding: 1rem;">
                                            <% const level = log.level || 'info'; %>
                                            <% if (level === 'error') { %>
                                                <span style="display: inline-block; padding: 0.25rem 0.75rem; background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: 4px; font-size: 0.8rem;">
                                                    ❌ Error
                                                </span>
                                            <% } else if (level === 'warning') { %>
                                                <span style="display: inline-block; padding: 0.25rem 0.75rem; background: rgba(245, 158, 11, 0.1); color: #f59e0b; border-radius: 4px; font-size: 0.8rem;">
                                                    ⚠️ Warning
                                                </span>
                                            <% } else if (level === 'success') { %>
                                                <span style="display: inline-block; padding: 0.25rem 0.75rem; background: rgba(16, 185, 129, 0.1); color: #10b981; border-radius: 4px; font-size: 0.8rem;">
                                                    ✅ Success
                                                </span>
                                            <% } else { %>
                                                <span style="display: inline-block; padding: 0.25rem 0.75rem; background: rgba(59, 130, 246, 0.1); color: #3b82f6; border-radius: 4px; font-size: 0.8rem;">
                                                    ℹ️ Info
                                                </span>
                                            <% } %>
                                        </td>
                                        <td style="padding: 1rem;">
                                            <%= log.plugin || 'System' %>
                                        </td>
                                        <td style="padding: 1rem;">
                                            <%= log.userId ? log.userId.substring(0, 8) + '...' : 'System' %>
                                        </td>
                                        <td style="padding: 1rem; max-width: 300px;">
                                            <div style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                <%= log.message || log.action || 'No message' %>
                                            </div>
                                        </td>
                                        <td style="padding: 1rem;">
                                            <button onclick="viewLogDetails('<%= log.id %>')" class="btn btn-sm btn-secondary">
                                                View
                                            </button>
                                            <button onclick="deleteLog('<%= log.id %>')" class="btn btn-sm btn-danger">
                                                Delete
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" style="text-align: center; padding: 3rem; color: var(--text-secondary);">
                                        <div style="font-size: 3rem; margin-bottom: 1rem;">📝</div>
                                        <h3>No system logs yet</h3>
                                        <p>System logs will appear here as activity occurs</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                
                <!-- Pagination -->
                <% if (logs && logs.length > 0) { %>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border);">
                        <div style="color: var(--text-secondary);">
                            Showing <%= logs.length %> of <%= totalLogs || logs.length %> logs
                        </div>
                        <div style="display: flex; gap: 0.5rem;">
                            <button onclick="changePage('prev')" class="btn btn-sm btn-secondary" <%= page <= 1 ? 'disabled' : '' %>>← Previous</button>
                            <span style="padding: 0.5rem 1rem; background: var(--bg-card); border-radius: 4px;">
                                Page <%= page || 1 %>
                            </span>
                            <button onclick="changePage('next')" class="btn btn-sm btn-secondary">Next →</button>
                        </div>
                    </div>
                <% } %>
            </div>
        </main>
    </div>
    
    <!-- Log Details Modal -->
    <div id="logDetailsModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 3000; align-items: center; justify-content: center;">
        <div class="card" style="max-width: 800px; max-height: 90vh; overflow-y: auto; width: 90%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h2>Log Details</h2>
                <button onclick="closeLogDetails()" class="btn btn-sm">✕</button>
            </div>
            
            <div id="logDetailsContent">
                <!-- Content loaded by JavaScript -->
            </div>
        </div>
    </div>
    
    <script>
        let currentPage = <%= page || 1 %>;
        
        function filterLogs() {
            const level = document.getElementById('logLevel').value;
            const plugin = document.getElementById('logPlugin').value;
            const timeRange = document.getElementById('logTime').value;
            const search = document.getElementById('logSearch').value.toLowerCase();
            
            const now = Date.now();
            let timeThreshold = 0;
            
            switch(timeRange) {
                case '1h': timeThreshold = now - (60 * 60 * 1000); break;
                case '24h': timeThreshold = now - (24 * 60 * 60 * 1000); break;
                case '7d': timeThreshold = now - (7 * 24 * 60 * 60 * 1000); break;
                case '30d': timeThreshold = now - (30 * 24 * 60 * 60 * 1000); break;
                default: timeThreshold = 0;
            }
            
            document.querySelectorAll('.log-row').forEach(row => {
                const rowLevel = row.dataset.level;
                const rowPlugin = row.dataset.plugin;
                const rowTime = parseInt(row.dataset.time);
                const rowText = row.textContent.toLowerCase();
                
                let show = true;
                
                if (level !== 'all' && rowLevel !== level) show = false;
                if (plugin !== 'all' && rowPlugin !== plugin) show = false;
                if (timeRange !== 'all' && rowTime < timeThreshold) show = false;
                if (search && !rowText.includes(search)) show = false;
                
                row.style.display = show ? 'table-row' : 'none';
            });
        }
        
        function refreshLogs() {
            window.location.reload();
        }
        
        function clearLogs() {
            if (confirm('Are you sure you want to clear all logs? This cannot be undone.')) {
                fetch('/admin/api/logs/clear', {
                    method: 'POST'
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showNotification('success', data.message);
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showNotification('error', data.error);
                    }
                });
            }
        }
        
        function exportLogs() {
            const level = document.getElementById('logLevel').value;
            const plugin = document.getElementById('logPlugin').value;
            const timeRange = document.getElementById('logTime').value;
            
            const params = new URLSearchParams({
                level: level !== 'all' ? level : '',
                plugin: plugin !== 'all' ? plugin : '',
                time: timeRange !== 'all' ? timeRange : ''
            });
            
            window.open(`/admin/api/logs/export?${params}`, '_blank');
        }
        
        function viewLogDetails(logId) {
            fetch(`/admin/api/logs/${logId}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const log = data.log;
                        
                        let detailsHtml = `
                            <div style="margin-bottom: 1.5rem;">
                                <strong>Time:</strong>
                                <div style="margin-top: 0.5rem; background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px;">
                                    ${new Date(log.timestamp).toLocaleString()}
                                </div>
                            </div>
                            
                            <div style="margin-bottom: 1.5rem;">
                                <strong>Level:</strong>
                                <div style="margin-top: 0.5rem;">
                                    <span style="display: inline-block; padding: 0.5rem 1rem; background: ${
                                        log.level === 'error' ? 'rgba(239, 68, 68, 0.1)' :
                                        log.level === 'warning' ? 'rgba(245, 158, 11, 0.1)' :
                                        log.level === 'success' ? 'rgba(16, 185, 129, 0.1)' :
                                        'rgba(59, 130, 246, 0.1)'
                                    }; color: ${
                                        log.level === 'error' ? '#ef4444' :
                                        log.level === 'warning' ? '#f59e0b' :
                                        log.level === 'success' ? '#10b981' :
                                        '#3b82f6'
                                    }; border-radius: 4px;">
                                        ${log.level === 'error' ? '❌ Error' :
                                          log.level === 'warning' ? '⚠️ Warning' :
                                          log.level === 'success' ? '✅ Success' :
                                          'ℹ️ Info'}
                                    </span>
                                </div>
                            </div>
                            
                            <div style="margin-bottom: 1.5rem;">
                                <strong>Plugin:</strong>
                                <div style="margin-top: 0.5rem; background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px;">
                                    ${log.plugin || 'System'}
                                </div>
                            </div>
                            
                            <div style="margin-bottom: 1.5rem;">
                                <strong>User:</strong>
                                <div style="margin-top: 0.5rem; background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px;">
                                    ${log.userId || 'System'}
                                </div>
                            </div>
                        `;
                        
                        if (log.message) {
                            detailsHtml += `
                                <div style="margin-bottom: 1.5rem;">
                                    <strong>Message:</strong>
                                    <div style="margin-top: 0.5rem; background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px; font-family: monospace; white-space: pre-wrap;">
                                        ${log.message}
                                    </div>
                                </div>
                            `;
                        }
                        
                        if (log.details) {
                            detailsHtml += `
                                <div style="margin-bottom: 1.5rem;">
                                    <strong>Details:</strong>
                                    <div style="margin-top: 0.5rem; background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px; font-family: monospace; white-space: pre-wrap;">
                                        ${JSON.stringify(log.details, null, 2)}
                                    </div>
                                </div>
                            `;
                        }
                        
                        if (log.error) {
                            detailsHtml += `
                                <div style="margin-bottom: 1.5rem;">
                                    <strong>Error:</strong>
                                    <div style="margin-top: 0.5rem; background: rgba(239, 68, 68, 0.1); padding: 1rem; border-radius: 8px; font-family: monospace; white-space: pre-wrap; color: #ef4444;">
                                        ${log.error}
                                    </div>
                                </div>
                            `;
                        }
                        
                        if (log.stackTrace) {
                            detailsHtml += `
                                <div style="margin-bottom: 1.5rem;">
                                    <strong>Stack Trace:</strong>
                                    <div style="margin-top: 0.5rem; background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px; font-family: monospace; white-space: pre-wrap; font-size: 0.9rem;">
                                        ${log.stackTrace}
                                    </div>
                                </div>
                            `;
                        }
                        
                        document.getElementById('logDetailsContent').innerHTML = detailsHtml;
                        document.getElementById('logDetailsModal').style.display = 'flex';
                    } else {
                        showNotification('error', data.error);
                    }
                });
        }
        
        function deleteLog(logId) {
            if (confirm('Are you sure you want to delete this log?')) {
                fetch(`/admin/api/logs/${logId}`, {
                    method: 'DELETE'
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showNotification('success', data.message);
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showNotification('error', data.error);
                    }
                });
            }
        }
        
        function closeLogDetails() {
            document.getElementById('logDetailsModal').style.display = 'none';
        }
        
        function changePage(direction) {
            if (direction === 'prev' && currentPage > 1) {
                window.location.href = `/admin/logs?page=${currentPage - 1}`;
            } else if (direction === 'next') {
                window.location.href = `/admin/logs?page=${currentPage + 1}`;
            }
        }
        
        // Close modal when clicking outside
        document.getElementById('logDetailsModal')?.addEventListener('click', (e) => {
            if (e.target.id === 'logDetailsModal') {
                closeLogDetails();
            }
        });
        
        // Auto-refresh every 30 seconds
        setInterval(refreshLogs, 30000);
    </script>
</body>
</html>
